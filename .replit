entrypoint = "README.md"
modules = ["nodejs-22", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["glib", "nspr", "nss", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXrandr", "mesa", "alsa-lib", "at-spi2-atk", "cups", "xorg.libXext", "xorg.libX11", "xorg.libxcb", "xorg.libXfixes", "xorg.libXi", "xorg.libXrender", "xorg.libXtst", "expat", "dbus", "pango", "cairo", "gtk3", "libxkbcommon", "zulu17"]

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 80

[[ports]]
localPort = 8083
externalPort = 3000

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx concurrently -k -n api,web -c blue,magenta \"NODE_ENV=development tsx server/index.ts\" \"npx vite --config web/vite.config.ts\""
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_OFFLINE=1 EXPO_NO_PROMPT=1 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost --clear --port 8082"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.development]
EXPO_PUBLIC_SANDBOX_MODE = "true"

[userenv.shared]

[userenv.production]
EXPO_PUBLIC_BACKEND_URL = "https://www.expathub.website"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
