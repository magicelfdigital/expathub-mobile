{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://www.expathub.website",
        "EXPO_PUBLIC_DOMAIN": "www.expathub.website"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "large"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://www.expathub.website",
        "EXPO_PUBLIC_DOMAIN": "www.expathub.website"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
